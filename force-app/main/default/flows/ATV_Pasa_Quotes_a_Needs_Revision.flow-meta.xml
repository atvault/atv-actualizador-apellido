<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <environments>Default</environments>
    <interviewLabel>Pasa Quotes a Needs Revision {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Pasa Quotes a Needs Revision</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>actualiza_estado_a_Needs_revision</name>
        <label>actualiza estado a Needs revision</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>ATV_Reset_Approval_Requested__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Needs Review</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>actualiza_estado_a_Needs_revision</targetReference>
        </connector>
        <filterFormula>AND(
  OR(
   ISPICKVAL({!$Record.Status}, &quot;Approved&quot;),
    ISPICKVAL({!$Record.Status}, &quot;Rejected&quot;),
    ISPICKVAL({!$Record.Status}, &quot;Accepted&quot;),
    ISPICKVAL({!$Record.Status}, &quot;Presented&quot;)
  ),
  NOT(ISCHANGED({!$Record.Status})),
  NOT(ISCHANGED({!$Record.ID_Netsuite__c})),
  NOT({!$Record.ATV_Override_flows__c}),
  NOT({!$Permission.ATV_Bypass_Flows})
)</filterFormula>
        <object>Quote</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
