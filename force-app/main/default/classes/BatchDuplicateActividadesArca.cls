    global void execute (Database.BatchableContext bc, List<ATV_ACTIVIDADES_ARCA__c> scope){
        System.debug('Execute - Batch');
        Set<Decimal> cuitSet = new Set<Decimal>();
        List<ATV_ACTIVIDADES_ARCA__c> actividadesToInsert = new List<ATV_ACTIVIDADES_ARCA__c>();
        Map<Decimal, Lead> leadMap = new Map<Decimal, Lead>();

        for(ATV_ACTIVIDADES_ARCA__c actividad : scope){
            cuitSet.add(actividad.Account__r.CUIT__c);
        }

        if(!cuitSet.isEmpty()){
            for(Lead lead: [SELECT Id, CUIT__c FROM Lead WHERE CUIT__c IN: cuitSet]){
                leadMap.put(lead.CUIT__c, lead);
            }

            for(ATV_ACTIVIDADES_ARCA__c actividad : scope){
                ATV_ACTIVIDADES_ARCA__c clone = actividad.clone(false, true, false, false);
                clone.Account__c = null;
                clone.ATV_Prospecto__c = leadMap.get(actividad.Account__r.CUIT__c).Id;
                actividadesToInsert.add(clone);
            }

            if(!actividadesToInsert.isEmpty()){
                insert actividadesToInsert;
            }
        }
    }
    
    global void finish (Database.BatchableContext bc){
        System.debug('Finish - Batch');
    }
