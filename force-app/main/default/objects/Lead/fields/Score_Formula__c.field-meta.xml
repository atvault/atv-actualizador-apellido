<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Score_Formula__c</fullName>
    <externalId>false</externalId>
    <formula>(($Setup.Factor_Importancia__c.Score_Nosis__c / 4) * Score_Nosis_Formula__c) +
(($Setup.Factor_Importancia__c.Nivel_Facturacion_Nosis__c / 3) * Nivel_Facturacion_Formula__c) +
(($Setup.Factor_Importancia__c.Rubro__c / 1) * Rubro_Formula__c) +
(($Setup.Factor_Importancia__c.Ubicacion__c / 4) * Ubicacion_Formula__c) +
(($Setup.Factor_Importancia__c.Empleados__c / 4) * Empleados_Formula__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Score Formula</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
