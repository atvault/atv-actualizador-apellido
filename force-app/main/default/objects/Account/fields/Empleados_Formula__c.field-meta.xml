<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Empleados_Formula__c</fullName>
    <externalId>false</externalId>
    <formula>IF(NumberOfEmployees  &lt;= 50, 0,
    IF(NumberOfEmployees &lt;= 100, 1,
        IF(NumberOfEmployees &lt;= 250, 2,
            IF(NumberOfEmployees &lt;= 500, 3,
                4
            )
        )
    )
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Empleados Formula</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
